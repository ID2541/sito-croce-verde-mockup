{
  "name": "croce-verde-frontend",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=22.13.1 <23"
  },
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\"",
    "dev": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\" && next dev -p 3000",
    "build": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\" && next build",
    "start": "next start -p 3000",
    "typecheck": "tsc --noEmit",
    "test": "node -e \"console.log('No frontend automated tests configured yet')\"",
    "ci:check": "pnpm run typecheck && pnpm run test && pnpm run build"
  },
  "dependencies": {
    "next": "^15.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2"
  }
}
