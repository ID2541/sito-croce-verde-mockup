{
  "name": "croce-verde-backend",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=22.13.1 <23"
  },
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start -p 3001",
    "typecheck": "tsc --noEmit",
    "test": "node --env-file=.env --import tsx --test tests/**/*.test.ts",
    "ci:check": "pnpm run typecheck && pnpm run test && pnpm run build",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:seed": "node --env-file=.env --import tsx prisma/seed.ts",
    "admin:bootstrap": "node --env-file=.env --import tsx scripts/bootstrap-admin.ts",
    "training:grant": "node --env-file=.env --import tsx scripts/create-training-access-grant.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.4.1",
    "next": "^15.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "prisma": "^6.4.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
