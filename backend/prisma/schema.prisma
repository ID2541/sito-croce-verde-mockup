generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  EDITOR
  STAFF
}

enum ContentStatus {
  DRAFT
  PUBLISHED
}

enum TransparencyStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  passwordHash String
  role         UserRole @default(STAFF)
  sessions     Session[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Post {
  id          String        @id @default(uuid()) @db.Uuid
  slug        String        @unique
  title       String
  excerpt     String
  content     String        @db.Text
  coverImage  String?
  category    String?
  publishedAt DateTime?
  status      ContentStatus @default(DRAFT)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Service {
  id          String   @id @default(uuid()) @db.Uuid
  slug        String   @unique
  title       String
  summary     String
  description String
  content     String   @db.Text
  category    String
  prenotabile Boolean  @default(false)
  icon        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Page {
  id        String   @id @default(uuid()) @db.Uuid
  slug      String   @unique
  title     String
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Faq {
  id         String        @id @default(uuid()) @db.Uuid
  slug       String        @unique
  question   String
  answer     String        @db.Text
  category   String
  sortOrder  Int           @default(0)
  isFeatured Boolean       @default(false)
  status     ContentStatus @default(PUBLISHED)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([status, category, sortOrder])
  @@index([isFeatured, sortOrder])
}

model TransparencyCategory {
  id          String                 @id @default(uuid()) @db.Uuid
  slug        String                 @unique
  title       String
  description String?                @db.Text
  parentId    String?                @db.Uuid
  parent      TransparencyCategory?   @relation("TransparencyCategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children    TransparencyCategory[]  @relation("TransparencyCategoryTree")
  sortOrder   Int                    @default(0)
  isActive    Boolean                @default(true)
  items       TransparencyItem[]
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  @@index([parentId])
  @@index([isActive, sortOrder])
}

model TransparencyItem {
  id            String                  @id @default(uuid()) @db.Uuid
  slug          String                  @unique
  title         String
  summary       String
  content       String?                 @db.Text
  categoryId    String                  @db.Uuid
  category      TransparencyCategory    @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  referenceYear Int?
  referenceDate DateTime?
  publishedAt   DateTime?
  status        TransparencyStatus      @default(DRAFT)
  featured      Boolean                 @default(false)
  documentFormat String                 @default("PDF")
  sortOrder     Int                     @default(0)
  documents     TransparencyDocument[]
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  @@index([categoryId, status])
  @@index([status, publishedAt])
  @@index([referenceYear])
  @@index([featured, sortOrder])
}

model TransparencyDocument {
  id             String              @id @default(uuid()) @db.Uuid
  itemId         String              @db.Uuid
  item           TransparencyItem    @relation(fields: [itemId], references: [id], onDelete: Cascade)
  label          String
  fileName       String
  publicUrl      String              @unique
  mimeType       String
  fileSizeBytes  Int?
  checksumSha256 String?
  language       String?
  isPrimary      Boolean             @default(false)
  sortOrder      Int                 @default(0)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([itemId, isPrimary, sortOrder])
}

model Location {
  id        String   @id @default(uuid()) @db.Uuid
  slug      String   @unique
  name      String
  area      String
  address   String
  phone     String?
  email     String?
  hours     String?
  mapUrl    String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Session {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model TrainingAccessGrant {
  id         String    @id @default(uuid()) @db.Uuid
  codeHash   String    @unique
  label      String
  expiresAt  DateTime
  revokedAt  DateTime?
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([expiresAt])
  @@index([revokedAt])
}
